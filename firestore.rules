rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: email
    // Fields:
    //   - email: string (required) - user's email
    //   - role: string (required) - 'admin', 'manager', 'pricing', 'cashier', 'salesperson'
    //   - isActive: boolean (required)
    //   - name: string (optional)
    //   - branchId: string (optional)
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - code: string (required)
    //   - name: string (required)
    //   - price: number (required)
    //   - inStock: boolean
    //   - quantity: number
    //   - isDeleted: boolean
    //
    // Collection: orders
    // Document ID: auto-generated
    // Fields:
    //   - branchId: string (required)
    //   - salespersonId: string (required)
    //   - salespersonName: string (required)
    //   - items: list (required)
    //   - totalOriginalPrice: number (required)
    //   - totalFinalPrice: number (required)
    //   - status: string (required) - 'pending', 'completed', 'cancelled', 'returned'
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isRootAdmin() {
      return isAuthenticated() && request.auth.token.email == 'szater600@gmail.com' && request.auth.token.email_verified == true;
    }

    function getUserRole() {
      // Use get() with a default to avoid errors if document doesn't exist
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.token.email));
      return userDoc != null ? userDoc.data.role : 'none';
    }

    function hasRole(role) {
      return isAuthenticated() && (isRootAdmin() || getUserRole() == role || getUserRole() == 'admin');
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['branchId', 'salespersonId', 'salespersonName', 'items', 'totalOriginalPrice', 'totalFinalPrice', 'status', 'createdAt']) &&
             data.branchId is string && data.branchId.size() > 0 && data.branchId.size() < 50 &&
             data.salespersonId is string && data.salespersonId.size() > 0 && data.salespersonId.size() < 50 &&
             data.salespersonName is string && data.salespersonName.size() > 0 && data.salespersonName.size() < 100 &&
             data.items is list && data.items.size() <= 100 &&
             data.totalOriginalPrice is number && data.totalOriginalPrice >= 0 &&
             data.totalFinalPrice is number && data.totalFinalPrice >= 0 &&
             data.status in ['pending', 'completed', 'cancelled', 'returned'] &&
             (!('requiresManagerApproval' in data) || data.requiresManagerApproval is bool) &&
             data.createdAt is timestamp;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['code', 'name', 'price']) &&
             data.code is string && data.code.size() > 0 && data.code.size() < 50 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'isActive']) &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'manager', 'pricing', 'cashier', 'salesperson'] &&
             data.isActive is bool;
    }

    match /users/{email} {
      allow read: if isAuthenticated();
      // Only root admin or existing admins can create/update users
      allow create, update: if (isRootAdmin() || hasRole('admin')) && isValidUser(request.resource.data);
      allow delete: if isRootAdmin() || hasRole('admin');
    }

    match /orders/{orderId} {
      // Anyone authenticated can read orders (salespersons need to see their own, cashiers need to see all, managers need to see all)
      allow read: if isAuthenticated();
      
      // Salespersons can create orders
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && request.resource.data.status == 'pending';
      
      // Cashiers can update orders (mark completed, cancelled, returned)
      // Salespersons can update their own pending orders
      allow update: if isAuthenticated() && isValidOrder(request.resource.data) && (
        // For now, allow any authenticated user to act as cashier to match UI
        // In a production app, this should be restricted to hasRole('cashier')
        true
      );
      
      // Only managers/admins can delete orders (though we use soft delete mostly)
      allow delete: if hasRole('manager') || isRootAdmin();
    }

    match /products/{productId} {
      // Anyone authenticated can read products
      allow read: if isAuthenticated();
      
      // Only pricing managers and admins can create/update/delete products
      allow create: if (hasRole('pricing') || isRootAdmin()) && isValidProduct(request.resource.data);
      allow update: if (hasRole('pricing') || isRootAdmin()) && isValidProduct(request.resource.data);
      allow delete: if hasRole('pricing') || isRootAdmin();
    }

    match /logs/{logId} {
      allow read: if isRootAdmin() || hasRole('admin') || hasRole('audit');
      allow create: if isAuthenticated();
      allow update, delete: if false; // Logs should be immutable
    }

    match /shifts/{shiftId} {
      allow read: if isAuthenticated(); // Users can see their own shifts, managers can see all
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow delete: if isRootAdmin() || hasRole('admin');
    }
  }
}
