{
  "name": "carpet-land-erp",
  "private": true,
  "version": "1.0.1",
  "description": "Carpet Land ERP for web, Android, and Windows desktop.",
  "author": "Carpet Land",
  "repository": {
    "type": "git",
    "url": "https://github.com/sayedblack3-star/carpet.git"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "client:apply": "node scripts/apply-client-config.mjs",
    "build": "vite build",
    "build:web": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "desktop:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:3000 && electron .\"",
    "desktop:start": "npm run build && electron .",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:dist": "npm run build && electron-builder --win nsis portable",
    "desktop:publish": "npm run build && electron-builder --win nsis portable --publish always",
    "mobile:copy": "npm run build && npx cap copy",
    "mobile:sync": "npm run build && npx cap sync android",
    "mobile:android": "npm run mobile:sync",
    "mobile:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.101.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/papaparse": "^5.5.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.carpetland.erp.desktop",
    "productName": "Carpet Land ERP",
    "directories": {
      "output": "desktop-release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "sayedblack3-star",
        "repo": "carpet"
      }
    ],
    "win": {
      "icon": "electron/assets/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
